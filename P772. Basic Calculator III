class Solution:
    def calculate(self, s: str) -> int:
        return self.helper(s, 0)[0]

    def helper(self, s, i):
        stack = []
        num = 0
        ope = '+'

        while i < len(s):
            char = s[i]

            if char.isdigit():
                num = num * 10 + int(char)

            if char == '(':
                num, i = self.helper(s, i + 1)

            if char in '+-*/)' or i == len(s) - 1:
                if ope == '+':
                    stack.append(num)
                elif ope == '-':
                    stack.append(-num) 

                elif ope == '*':
                    stack.append(stack.pop() * num)

                elif ope == '/':
                    stack.append(int(stack.pop() / num))

                ope = char 
                num = 0

            if char == ')':
                return sum(stack), i 

            i += 1

        return sum(stack), i

