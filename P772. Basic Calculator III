class Solution:
    def calculate(self, s: str) -> int:
        def helper(i):
            stack = []
            num = 0
            sign = '+'

            while i < len(s):
                ch = s[i]

                if ch.isdigit():
                    num = num * 10 + int(ch)

                if ch == '(':
                    num, i = helper(i + 1)

                if ch in "+-*/)" or i == len(s) - 1:
                    if sign == '+':
                        stack.append(num)
                    elif sign == '-':
                        stack.append(-num)
                    elif sign == '*':
                        stack.append(stack.pop() * num)
                    elif sign == '/':
                        stack.append(int(stack.pop() / num))

                    sign = ch
                    num = 0

                if ch == ')':
                    return sum(stack), i

                i += 1

            return sum(stack), i

        return helper(0)[0]
