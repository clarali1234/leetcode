

class Solution:
    def getFactors(self, n: int) -> List[List[int]]:
        if n == 1:
            return []

        self.res = []
        self.dfs(2, n, [])
        return self.res

    def dfs(self, start, n, path):
    
        for i in range(start, int(sqrt(n)) + 1):
            if n % i == 0:
                self.res.append(path + [i, n // i])
                self.dfs(i, n // i, path + [i])

        


