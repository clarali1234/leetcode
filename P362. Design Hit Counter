class HitCounter:

    def __init__(self):
        self.nums = []

    def hit(self, timestamp: int) -> None:
        self.nums.append(timestamp)

    def getHits(self, timestamp: int) -> int:
        target = timestamp - 300

        # fisrt index > timestamp - 300 (0, 300]
        idx = self.bs(self.nums, target)
        return len(self.nums) - idx

    def bs(self, nums, target):
        l = 0
        r = len(nums)
        while l < r:
            m = (l + r) // 2
            if nums[m] > target:
                r = m
            else:
                l = m + 1
        return l

class HitCounter:

    def __init__(self):
        self.nums = []

    def hit(self, timestamp: int) -> None:
        self.nums.append(timestamp)
        

    def getHits(self, timestamp: int) -> int:
        if not self.nums:
            return 0

        # find first index > timestamp - 300 
        l = 0
        r = len(self.nums) - 1
        while l + 1 < r:
            m = (l + r) // 2
            if self.nums[m] <= timestamp - 300:
                l = m + 1
            else:
                r = m

        if self.nums[l] > timestamp - 300:
            index = l

        elif self.nums[r] > timestamp - 300:
            index = r
        else:
            return 0


        return len(self.nums) - index



