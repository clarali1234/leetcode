# using deque
那么最直接的方法就是用一个队列queue，每次点击时都将当前时间戳加入queue中，
然后在需要获取点击数时，我们从队列开头开始看，如果开头的时间戳在5分钟以外了，
就删掉，直到开头的时间戳在5分钟以内停止，然后返回queue的元素个数即为所求的点击数

# time hit O(1), getHits O(n) 
# space O(n)

class HitCounter(object):
    def __init__(self):
        self.time = collections.deque([])

    def hit(self, timestamp):
        self.time.append(timestamp)
        

    def getHits(self, timestamp):   
        while self.time and timestamp - self.time[0] >= 300:
            self.time.popleft()
        return len(self.time)
        

# follow up:hits很大，不需要保留旧数据
# key:time, value: num of hits at this time
最优，节省空间
class HitCounter:

    def __init__(self):
        self.times = [0] * 300
        self.hits = [0] * 300

    def hit(self, timestamp: int) -> None:
        idx = timestamp % 300
        if self.times[idx] != timestamp:
            self.hits[idx] = 1
            self.times[idx] = timestamp
        else:
            self.hits[idx] += 1
        

    def getHits(self, timestamp: int) -> int:
        res = 0
        for idx, t in enumerate(self.times):
            if  timestamp - t < 300:
                res += self.hits[idx]

        return res

        

# sol4 save space，hit sparse, 用dic + 清理

# time hit/get hit O(1)
# space O(1)
class HitCounter:

    def __init__(self):
        self.dic = collections.defaultdict(int)

    def hit(self, timestamp: int) -> None:
        self.dic[timestamp] += 1

    def getHits(self, timestamp: int) -> int:
        res = 0
        expired = []
        for t, hit in self.dic.items():
            if timestamp - t < 300:
                res += hit 
            else:
                expired.append(t)

        for t in expired:
            del self.dic[t]
        return res


# sol5: map + deque
sparse but high-volume hits (many hits occurring at specific, distant time points).
Deque (self.queue): Stores unique timestamps in increasing order. This allows for $O(1)$ removal of old data from the front.

class HitCounter:

    def __init__(self):
        self.dic = collections.defaultdict(int)
        self.q = collections.deque([])
        self.total = 0

    def hit(self, timestamp: int) -> None:
        if timestamp not in self.dic:
            self.dic[timestamp] = 1
            self.q.append(timestamp)
        else:
            self.dic[timestamp] += 1
        self.total += 1
        
    
    def getHits(self, timestamp: int) -> int:

        cutoff = timestamp - 300
        while self.q and self.q[0] <= cutoff:
            old_time = self.q.popleft()
            self.total -= self.dic[old_time]
            del self.dic[old_time]
        return self.total


class HitCounter:

    def __init__(self):
        self.dic = collections.defaultdict(int)
        self.q = collections.deque([])

    def hit(self, timestamp: int) -> None:
        if timestamp not in self.dic:
            self.dic[timestamp] = 1
            self.q.append(timestamp)
        else:
            self.dic[timestamp] += 1
        

    def getHits(self, timestamp: int) -> int:
        while self.q and timestamp - 299 > self.q[0]:
            oldtime = self.q.popleft()
            del self.dic[oldtime]

        return sum(self.dic.values())

        



        


