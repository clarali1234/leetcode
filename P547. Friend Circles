# space O(n) visisted array of size n
class Solution(object):
    def findCircleNum(self, M):
        """
        :type M: List[List[int]]
        :rtype: int
        """
        visited = set()
        queue = collections.deque([])
        
        n = len(M)
        count = 0
        for i in range(n):
            if i not in visited:
                queue.append(i)
                visited.add(i)
                while queue:
                    node = queue.popleft()
                    for j, fri in enumerate(M[node]):
                        if j not in visited and fri == 1:
                            queue.append(j)
                            visited.add(j)
            
                count += 1
        return count
            
