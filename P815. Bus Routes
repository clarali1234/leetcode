time: build graph O(m*n), bfs(m*n)
space: O(m*n)

难点在于如何构建图: (key, value) -> key: stops, value: bus routes (stops to routes relationships)

class Solution:
    def numBusesToDestination(self, routes: List[List[int]], source: int, target: int) -> int:
        if source == target:
            return 0
        
        graph = collections.defaultdict(list) # stop -> bus id
        for bus_id, stops in enumerate(routes):
            for stop in stops:
                graph[stop].append(bus_id)

        q = collections.deque([])
        visited_bus = set()

        for bus_id in graph[source]:
            q.append((bus_id, 1))
            visited_bus.add(bus_id)

        while q:
            bus_id, count = q.popleft()
            for stop in routes[bus_id]:
                if stop == target:
                    return count 

                for next_bus_id in graph[stop]:
                    if next_bus_id not in visited_bus:
                        q.append((next_bus_id, count + 1))
                        visited_bus.add(next_bus_id)
        return -1



