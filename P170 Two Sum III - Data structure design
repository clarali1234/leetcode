        self.dic[number] = self.dic.get(number, 0) + 1

    def find(self, value: int) -> bool:
        for num in self.dic:
            n2 = value - num 
            if n2 != num:
                if n2 in self.dic:
                    return True
                return False
            else:
                if self.dic[num] > 1:
