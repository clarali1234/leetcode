# time O(mn)
# space O(mn)

class Solution:
    def findDiagonalOrder(self, mat: List[List[int]]) -> List[int]:
        m = len(mat)
        n = len(mat[0])

        dic = collections.defaultdict(list)
        for i in range(m):
            for j in range(n):
                dic[i + j].append(mat[i][j])

        res = []
        for i in range(m + n - 1):
            if i % 2 == 0:
                res.extend(dic[i][::-1])
            else:
                res.extend(dic[i])
        return res
        
        
