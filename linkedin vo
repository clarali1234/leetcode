1. Implement a function mergeTrees(TreeNode root1, TreeNode root2) that takes two n-ary trees and returns a new n-ary tree formed by
merging them node by node. Each node contains an integer value and a list of children; children are aligned by their index in the children list.
The merge rules are: If both trees have a node at the same position (0-based children array), the merged node's value is the sum of the two 
original values. If only one tree has a node at a position, the merged tree should include a copy of that entire subtree.


class Node:
    def __init__(self, val, children=None):
        self.val = val
        self.children = children or []


def mergeTrees(root1, root2):

    # 情况1：都为空
    if not root1 and not root2:
        return None

    # 情况2：只存在一个 → 深拷贝
    if not root1:
        return clone(root2)
    if not root2:
        return clone(root1)

    # 情况3：都存在 → 合并当前节点
    new_root = Node(root1.val + root2.val)

    len1, len2 = len(root1.children), len(root2.children)
    max_len = max(len1, len2)

    for i in range(max_len):
        c1 = root1.children[i] if i < len1 else None
        c2 = root2.children[i] if i < len2 else None
        new_root.children.append(mergeTrees(c1, c2))

    return new_root


def clone(node):
    if not node:
        return None
    new_node = Node(node.val)
    for child in node.children:
        new_node.children.append(clone(child))
    return new_node


2. import threading

class Node:
    def __init__(self, key, val):
        self.key = key
        self.val = val
        self.prev = self.next = None


class LRUCache:
    def __init__(self, capacity):
        self.cap = capacity
        self.map = {}

        self.head = Node(0, 0)
        self.tail = Node(0, 0)
        self.head.next = self.tail
        self.tail.prev = self.head

        self.lock = threading.Lock()

    def _remove(self, node):
        node.prev.next = node.next
        node.next.prev = node.prev

    def _add_to_head(self, node):
        node.next = self.head.next
        node.prev = self.head
        self.head.next.prev = node
        self.head.next = node

    def get(self, key):
        with self.lock:
            if key not in self.map:
                return -1
            node = self.map[key]
            self._remove(node)
            self._add_to_head(node)
            return node.val

    def put(self, key, value):
        with self.lock:
            if key in self.map:
                node = self.map[key]
                node.val = value
                self._remove(node)
                self._add_to_head(node)
            else:
                node = Node(key, value)
                self.map[key] = node
                self._add_to_head(node)

                if len(self.map) > self.cap:
                    lru = self.tail.prev
                    self._remove(lru)
                    del self.map[lru.key]


3. from collections import deque, defaultdict

class AlertMonitor:

    def __init__(self):
        self.q = deque()  # (ts, level)
        self.level_count = defaultdict(int)
        self.total = 0

        self.history = []   # 每个时间点的 count
        self.stack = []     # 单调栈 (index)

        self.WINDOW = 900  # 15 min = 900 sec

    def _evict(self, ts):
        # 移除窗口外数据
        while self.q and self.q[0][0] < ts - self.WINDOW:
            old_ts, level = self.q.popleft()
            self.level_count[level] -= 1
            self.total -= 1

    def addAlert(self, ts, level):
        self.q.append((ts, level))
        self.level_count[level] += 1
        self.total += 1

    def getCount(self, ts):
        self._evict(ts)
        return self.total

    def getDistribution(self, ts):
        self._evict(ts)
        return dict(self.level_count)

    def getSpike(self, ts):
        self._evict(ts)

        cur = self.total
        idx = len(self.history)

        # 单调栈：维护递增
        while self.stack and self.history[self.stack[-1]] >= cur:
            self.stack.pop()

        # 找左边第一个更小
        res = self.stack[-1] if self.stack else -1

        self.history.append(cur)
        self.stack.append(idx)

        return res


1004. Max Consecutive Ones III 变种 有2，obstacle

def longestOnesWithObstacle(nums, k):
    left = 0
    zeros = 0
    res = 0
    
    for right in range(len(nums)):
        if nums[right] == 2:
            # 遇到障碍，重置窗口
            left = right + 1
            zeros = 0
            continue
        
        if nums[right] == 0:
            zeros += 1
        
        while zeros > k:
            if nums[left] == 0:
                zeros -= 1
            left += 1
        
        res = max(res, right - left + 1)
    
    return res
