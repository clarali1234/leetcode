
sliding window
maintain types <= 2, find the max res of continuous subarray


class Solution:
    def totalFruit(self, fruits: List[int]) -> int:
        # longest subarry with at most 2 diff elements
        i = 0
        res = 0
        dic = collections.defaultdict(int)
        for j in range(len(fruits)):
            dic[fruits[j]] += 1

            while len(dic) >= 3:
                dic[fruits[i]] -= 1
                if dic[fruits[i]] == 0:
                    del dic[fruits[i]]
                i += 1

            res = max(res, j - i + 1)
        return res


            

