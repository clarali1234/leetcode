# time O(nk^2)
# space O(k)

class Solution:
    def minCostII(self, costs: List[List[int]]) -> int:
        # dp[i][j] = cost[i][j] + min(dp[i - 1][l] l != i)
        n = len(costs)
        k = len(costs[0])

        prev_dp = costs[0]

        for i in range(1, n):
            cur_dp = [0] * k
            for j in range(k):
                cur_dp[j] = costs[i][j] + min(prev_dp[:j] + prev_dp[j + 1:])
            prev_dp = cur_dp
        return min(prev_dp)
            
