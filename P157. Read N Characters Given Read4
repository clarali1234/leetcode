# 目的，把文件内容读在buf里；返回max(len(file, n))


class Solution:
    def read(self, buf, n):
        """
        :type buf: Destination buffer (List[str])
        :type n: Number of characters to read (int)
        :rtype: The number of actual characters read (int)
        """
        total = 0
        buf4 = [''] * 4

        while total < n:
            count = read4(buf4)
            if count == 0:
                break

            copy = min(count, n - total)
            for i in range(copy):
                buf[total] = buf4[i]
                total += 1

        return total



class Solution:
    def read(self, buf, n):
        buf4 = [''] * 4
        total = 0  # 已读取总数
        
        while total < n:
            count = read4(buf4)  # 实际读取数量
            
            # 如果 read4 返回 0，说明 EOF
            if count == 0:
                break
            
            # 把 buf4 的内容拷贝到 buf
            for i in range(count):
                if total == n:
                    break
                buf[total] = buf4[i]
                total += 1
        
        return total
