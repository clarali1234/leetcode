# The read4 API is already defined for you.
# def read4(buf4: List[str]) -> int:

class Solution:
    def __init__(self):
        self.buffer = [''] * 4
        self.pointer = 0
        self.count = 0


    def read(self, buf: List[str], n: int) -> int:
        i = 0
        while i < n:
            # 如果 buffer 用完了 → 调 read4
            if self.pointer == self.count:
                self.count = read4(self.buffer)
                self.pointer = 0

                # EOF
                if self.count == 0:
                    break
            # 从 buffer 搬到目标 buf
            while i < n and self.pointer < self.count:
                buf[i] = self.buffer[self.pointer]
                self.pointer += 1
                i += 1

        return i
        
                
        
