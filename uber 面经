class Solution:
    def topoResult(self, graph, target):
        self.color = {}
        self.res = []
        if not self.dfs(graph, target):
            return self.res
        return []
        
    def dfs(self, graph, node):
        if node in self.color:
            if self.color[node] == 1:
                return True
                
            if self.color[node] == 2:
                return False
                
            
        self.color[node] = 1 
        for nb in graph[node]:
            if self.dfs(graph, nb):
                return True
                
        self.color[node] = 2
        self.res.append(node)
        return False
        
