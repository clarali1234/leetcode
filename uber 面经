TopSmallestKCustomer : 返回最小的TOP K REVENUE的ID。 会要求revenu> NUM之后最小的TOP k.

from sortedcontainers import SortedList


class CustomerRevenueSystem:
    def __init__(self):
        self.next_id = 1

        # customer_id -> revenue
        self.id_to_revenue = {}

        # sorted by (revenue, id)
        self.sorted_customers = SortedList()

    def add(self, revenue):
        customer_id = self.next_id
        self.next_id += 1

        self.id_to_revenue[customer_id] = revenue
        self.sorted_customers.add((revenue, customer_id))

        return customer_id

    def addByReferral(self, revenue, referrer_id):
        if referrer_id not in self.id_to_revenue:
            return -1

        old_revenue = self.id_to_revenue[referrer_id]

        # remove old value
        self.sorted_customers.remove((old_revenue, referrer_id))

        # update referrer revenue
        new_revenue = old_revenue + revenue
        self.id_to_revenue[referrer_id] = new_revenue
        self.sorted_customers.add((new_revenue, referrer_id))

        # new customer gets original referrer's revenue
        new_customer_id = self.next_id
        self.next_id += 1

        self.id_to_revenue[new_customer_id] = old_revenue
        self.sorted_customers.add((old_revenue, new_customer_id))

        return new_customer_id

    def topSmallestKCustomer(self, k):
        result = []

        for revenue, customer_id in self.sorted_customers[:k]:
            result.append(customer_id)

        return result

    def topSmallestKCustomerWithThreshold(self, k, num):
        result = []

        # binary search first revenue > num
        idx = self.sorted_customers.bisect_right((num, float('inf')))

        for i in range(idx, min(idx + k, len(self.sorted_customers))):
            result.append(self.sorted_customers[i][1])

        return result

